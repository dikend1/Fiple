<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Unsandboxed posture, used by TWO configs (see project.yml):
	     Debug (local dev) and Release-DevID (the notarized fiple.app/download
	     build). The terminal needs a real, un-sandboxed login shell (brew, git,
	     user projects), which the App Sandbox forbids — so the terminal ships
	     ONLY via Developer ID, never through the Mac App Store. The sandboxed
	     MAS posture lives in Fiple.entitlements (config Release-MAS). -->
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
</dict>
</plist>
