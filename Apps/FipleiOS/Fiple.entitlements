<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- No aps-environment: the app registers no push/CloudKit subscriptions,
	     and a hardcoded `development` value would fail App Store validation. -->
	<!-- iCloud/CloudKit entitlements are intentionally absent for the 1.0
	     LAN-only release (off-LAN Files is disabled via AppFeatures.remoteFiles).
	     Restore com.apple.developer.icloud-container-identifiers and
	     com.apple.developer.icloud-services (CloudKit) for the 1.1 Files release. -->
	<!-- Shared with the FipleShare extension so it can read the pairing token
	     and beam files without opening the app. Listed FIRST so new writes land
	     in the shared group; the app-private group stays readable for items
	     written by older builds. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.maksatov.fipleapp.shared</string>
		<string>$(AppIdentifierPrefix)com.maksatov.fipleapp</string>
	</array>
</dict>
</plist>
